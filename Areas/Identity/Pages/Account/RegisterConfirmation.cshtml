@page
@model RegisterConfirmationModel
@{
    ViewData["title"] = "confirm registration";
    Layout = "/views/shared/_layouttest.cshtml";
}

<div class="flex-1 flex flex-col items-center justify-center py-20 px-4 min-h-[70vh]">
    <div class="w-full max-w-md bg-[#1c2228] p-10 rounded-3xl border border-[#2d3640] shadow-2xl text-center relative overflow-hidden">
        
        @* decoratiune gradient in spate *@
        <div class="absolute -top-24 -right-24 size-48 bg-primary/10 blur-3xl rounded-full"></div>

        <div class="size-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-8 border border-primary/20 relative z-10">
            <span class="material-symbols-outlined text-primary text-4xl animate-pulse">mark_email_read</span>
        </div>

        <h1 class="text-3xl font-black text-white mb-4 tracking-tight uppercase relative z-10">
            check your <span class="text-gradient">sparks</span>
        </h1>
        
        <p class="text-[#94a3b8] mb-10 font-medium leading-relaxed relative z-10">
            we need to verify your identity before you join the circle. 
        </p>

        @if (Model.DisplayConfirmAccountLink)
        {
            @* link-ul de confirmare stilizat ca butonul principal din aplicatie *@
            <div class="relative z-10">
                <p class="text-xs text-gray-500 uppercase font-bold mb-4 tracking-widest">click the button below</p>
                <a id="confirm-link" href="@Model.EmailConfirmationUrl" 
                   class="inline-block w-full bg-gradient-to-r from-[#2dd4bf] to-[#22d3ee] text-[#0f1115] font-black py-4 px-8 rounded-xl hover:opacity-90 transition-all shadow-lg shadow-primary/20 text-sm uppercase tracking-widest text-decoration-none">
                    confirm account
                </a>
            </div>
        }
        else
        {
            <p class="text-primary font-bold animate-bounce">please check your inbox to activate your profile.</p>
        }

        <div class="mt-8 pt-8 border-t border-[#2d3640] relative z-10">
            <a href="/" class="text-[#94a3b8] hover:text-white text-xs font-bold uppercase tracking-widest transition-colors text-decoration-none">
                back to home
            </a>
        </div>
    </div>
</div>