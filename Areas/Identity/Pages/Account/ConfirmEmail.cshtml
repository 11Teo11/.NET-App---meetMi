@page
@model ConfirmEmailModel
@{
    ViewData["title"] = "Email confirmed";
    Layout = "/views/shared/_layouttest.cshtml";
}

<div class="flex-1 flex flex-col items-center justify-center py-20 px-4 min-h-[70vh]">
    <div class="w-full max-w-md bg-[#1c2228] p-10 rounded-3xl border border-[#2d3640] shadow-2xl text-center relative overflow-hidden">

        @* decoratiune gradient *@
        <div class="absolute -bottom-24 -left-24 size-48 bg-primary/10 blur-3xl rounded-full"></div>

        @* iconita de succes *@
        <div class="size-24 bg-[#2dd4bf]/10 rounded-full flex items-center justify-center mx-auto mb-8 border-2 border-[#2dd4bf]/30 relative z-10">
            <span class="material-symbols-outlined text-[#2dd4bf] text-5xl animate-bounce">verified_user</span>
        </div>

        <h1 class="text-3xl font-black text-white mb-4 tracking-tight uppercase relative z-10">
            spark <span class="text-gradient">activated!</span>
        </h1>

        <p class="text-[#94a3b8] mb-10 font-medium leading-relaxed relative z-10">
            thank you for confirming your email. your identity is now verified and you are ready to join the circle.
        </p>

        @* buton de login *@
        <div class="relative z-10">
            <a asp-page="./Login"
               class="inline-block w-full bg-gradient-to-r from-[#2dd4bf] to-[#22d3ee] text-[#0f1115] font-black py-4 px-8 rounded-xl hover:opacity-90 transition-all shadow-lg shadow-[#2dd4bf]/20 text-sm uppercase tracking-widest text-decoration-none">
                go to login
            </a>
        </div>

        <div class="mt-8 pt-8 border-t border-[#2d3640] relative z-10">
            <p class="text-[10px] text-gray-500 uppercase font-black tracking-[0.2em]">
                welcome to meetmi circle
            </p>
        </div>
    </div>
</div>