@model ProiectDotNet.Models.Group
@{
    bool isMember = ViewBag.IsMember ?? false;
    bool isModerator = ViewBag.IsModerator ?? false;
    bool isAdmin = ViewBag.IsAdmin ?? false;
    bool isPending = ViewBag.IsPending ?? false;
    int pendingCount = ViewBag.PendingRequestsCount ?? 0;
}

<div class="relative bg-gradient-to-br from-[#1c2228] to-[#161b20] p-6 rounded-2xl border border-[#2dd4bf]/30 shadow-2xl text-center overflow-hidden">
    @if (isMember && !isModerator && !isAdmin)
    {
        <div id="member-actions" class="flex flex-col gap-3">
            <span class="flex items-center justify-center gap-2 w-full py-2 text-[#2dd4bf] font-black uppercase text-[10px]">
                <span class="material-symbols-outlined text-sm">check_circle</span> Member
            </span>
            <button onclick="toggleLeaveConfirm(true)" class="w-full py-3 rounded-xl border border-red-500/20 text-red-500 font-black uppercase text-[10px] hover:bg-red-500/5">
                Leave Squad
            </button>
        </div>

        <div id="leave-confirm-ui" class="hidden flex flex-col gap-3">
            <p class="text-white text-[10px] font-black uppercase tracking-widest mb-2">Are you sure?</p>
            <div class="flex gap-2">
                <form asp-controller="GroupMembers" asp-action="Remove" asp-route-groupId="@Model.Id" asp-route-userId="@ViewBag.UserCurent" method="post" class="flex-1">
                    <button type="submit" class="w-full py-3 bg-red-500 text-white rounded-xl font-black uppercase text-[10px]">Yes</button>
                </form>
                <button onclick="toggleLeaveConfirm(false)" class="flex-1 py-3 bg-[#2d3640] text-white rounded-xl font-black uppercase text-[10px]">No</button>
            </div>
        </div>
    }
    else if (!isMember && !isPending && !isModerator && !isAdmin)
    {
        @* buton join pentru vizitatori *@
        <form asp-controller="GroupMembers" asp-action="Join" asp-route-groupId="@Model.Id" method="post">
            <button type="submit" class="w-full py-4 rounded-xl bg-gradient-to-r from-[#2dd4bf] to-[#facc15] text-[#102220] font-black uppercase text-[10px] shadow-lg hover:scale-[1.02] transition-transform">
                @(Model.IsPublic ? "Join Now" : "Request Access")
            </button>
        </form>
    }
    else if (isPending)
    {
        <button disabled class="w-full py-4 rounded-xl bg-[#2d3640] text-[#94a3b8] font-black uppercase text-[10px]">Pending Approval</button>
    }

    @if (isModerator || isAdmin)
    {
        <div class="flex flex-col gap-2 mt-2">
            @if (isModerator)
            {
                <a asp-controller="Groups" asp-action="Edit" asp-route-id="@Model.Id" class="w-full py-3 rounded-xl border border-[#2dd4bf]/20 text-[#2dd4bf] font-black uppercase text-[10px] text-center hover:bg-[#2dd4bf]/5 transition-all block">Edit Squad</a>
                <a asp-controller="GroupMembers" asp-action="Requests" asp-route-groupId="@Model.Id" class="relative w-full py-3 rounded-xl border border-[#2dd4bf]/20 text-[#2dd4bf] font-black uppercase text-[10px] text-center hover:bg-[#2dd4bf]/5 transition-all block">
                    Manage Requests
                    @if (pendingCount > 0)
                    {
                        <span class="absolute -top-2 -right-1 size-5 bg-red-500 text-white text-[10px] flex items-center justify-center rounded-full border-2 border-[#1c2228] font-black shadow-lg">@pendingCount</span>
                    }
                </a>
            }
            else
            {
                @* adminul poate doar sterge grupul *@
                <a asp-controller="Groups" asp-action="Edit" asp-route-id="@Model.Id" class="w-full py-3 rounded-xl border border-red-500/20 text-red-500 font-black uppercase text-[10px] text-center hover:bg-red-500/5 transition-all block">Delete Squad</a>
            }
        </div>
    }
</div>