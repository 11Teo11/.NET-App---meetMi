@model ProiectDotNet.Models.ApplicationUser
@{
    // setari titlu si layout principal
    ViewData["Title"] = Model.FirstName + "'s Profile";
    Layout = "/Views/Shared/_LayoutTest.cshtml";

    // preluare date din viewbag pentru starea profilului
    bool isProfileHidden = ViewBag.IsProfileHidden;
    bool isFollowing = ViewBag.IsFollowing;
    bool isPending = ViewBag.IsPending;
    bool isOwnProfile = ViewBag.IsOwnProfile;
    var userPosts = ViewBag.UserPosts as IEnumerable<ProiectDotNet.Models.Post>;

    // date pentru compatibilitate si personalitate
    int compatibilityScore = ViewBag.CompatibilityScore ?? 0;
    string targetPersonality = ViewBag.TargetPersonalityType ?? "Unknown";
}

<main class="flex-1 h-full bg-[#0f1115] flex justify-center w-full">
    @* container centrat fara coloana laterala *@
    <div class="w-full max-w-4xl flex flex-col gap-6 p-4 md:p-6 lg:p-8">

        @* zona de header: banner si informatii utilizator *@
        <div class="w-full flex flex-col gap-6">
            @* imagine de fundal stilizata *@
            <div class="h-48 md:h-64 w-full rounded-xl bg-cover bg-center relative group overflow-hidden border border-[#2d3640]"
                 style="background-image: url('@(Model.CoverPicture ?? "/images/default-cover.png")');">
                <div class="absolute inset-0 bg-black/20"></div>

                @* insigna compatibilitate dinamica *@
                @if (!isOwnProfile && compatibilityScore > 0)
                {
                    <div class="absolute top-4 right-4 bg-[#0f1115]/80 backdrop-blur-md px-4 py-1.5 rounded-full border border-[#2dd4bf]/40 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[#facc15] text-sm">bolt</span>
                        <span class="text-xs font-bold text-white">@compatibilityScore% Compatibility!</span>
                    </div>
                }
            </div>

            @* sectiune avatar si date profil *@
            <div class="flex flex-col md:flex-row gap-6 px-2 md:px-4 relative">

                @* poza de profil care se suprapune peste banner *@
                <div class="shrink-0 -mt-20 md:-mt-24 ml-4 md:ml-0 relative">
                    <div class="size-32 md:size-40 rounded-full border-4 border-[#0f1115] bg-cover bg-center shadow-lg z-10"
                         style="background-image: url('@(Model.ProfilePicture ?? "/images/default-avatar.png")');"></div>
                </div>

                <div class="flex flex-col gap-2 flex-1 pt-1">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">

                        <div>
                            <h1 class="text-3xl font-bold text-white tracking-tight flex items-center gap-2">
                                @Model.FirstName @Model.LastName
                                <span class="material-symbols-outlined text-[#2dd4bf] text-xl">verified</span>
                            </h1>
                            <p class="text-[#94a3b8]">@@@Model.UserName</p>
                        </div>

                        @* butoane de interactiune sau editare *@
                        <div class="flex items-center gap-3">
                            @if (isOwnProfile)
                            {
                                <a href="/Profiles/Edit" class="bg-[#1c2228] border border-[#2d3640] hover:bg-[#161b20] text-white px-6 py-2 rounded-lg font-bold text-sm transition-all text-decoration-none">
                                    Edit Profile
                                </a>
                            }
                            else
                            {
                                @if (User.Identity.IsAuthenticated)
                                {
                                <form asp-controller="Profiles" asp-action="ToggleFollow" asp-route-id="@Model.Id" method="post" class="flex items-center gap-2">
                                    @if (isFollowing)
                                    {
                                        <button type="submit" class="bg-[#1c2228] border border-[#2d3640] text-white px-6 py-2 rounded-lg font-bold text-sm">Unfollow</button>
                                    }
                                    else if (isPending)
                                    {
                                        <button type="submit" class="bg-[#1c2228]/50 border border-[#2d3640] text-[#94a3b8] px-6 py-2 rounded-lg font-bold text-sm italic">Requested</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="bg-gradient-to-r from-[#2dd4bf] to-[#22d3ee] text-[#0f1115] px-6 py-2 rounded-lg font-bold text-sm flex items-center gap-2 shadow-lg shadow-[#2dd4bf]/20 border-0">
                                            <span class="material-symbols-outlined text-base">person_add</span> Connect
                                        </button>
                                    }
                                </form>
                                    

                                    @* buton stergere pentru admin cu confirmare integrata *@
                                    @if (User.IsInRole("Admin") && !isOwnProfile)
                                    {
                                        <div class="flex flex-col gap-2">
                                            <button type="button" id="admin-delete-start" onclick="showAdminDeleteConfirm()" class="bg-red-500/10 border border-red-500/50 text-red-500 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg font-bold text-sm transition-all flex items-center gap-2">
                                                <span class="material-symbols-outlined text-base">delete</span>
                                                Delete User
                                            </button>

                                            @* caseta de confirmare pentru admin *@
                                            <div id="admin-delete-confirm-box" class="hidden bg-[#1c2228] border border-red-500/30 p-4 rounded-xl flex flex-col gap-3">
                                                <p class="text-xs text-red-500 font-bold uppercase">Confirm deletion for this user?</p>
                                                <div class="flex gap-2">
                                                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                                                        <button type="submit" class="bg-red-500 text-white text-[10px] font-black px-3 py-1.5 rounded uppercase border-0">Confirm</button>
                                                    </form>
                                                    <button type="button" onclick="hideAdminDeleteConfirm()" class="bg-gray-700 text-white text-[10px] font-black px-3 py-1.5 rounded uppercase border-0">Cancel</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>

                    @* descriere bio *@
                    <p class="text-gray-300 mt-2 max-w-2xl leading-relaxed">@Model.Description</p>

                    @* contoare statistice din tabela requests *@
                    <div class="flex items-center gap-6 mt-3 text-sm">
                        <div class="flex items-center gap-1 text-white">
                            <span class="font-bold text-lg">@ViewBag.FollowersCount</span> <span class="text-[#94a3b8]">Followers</span>
                        </div>
                        <div class="flex items-center gap-1 text-white">
                            <span class="font-bold text-lg">@ViewBag.FollowingCount</span> <span class="text-[#94a3b8]">Following</span>
                        </div>
                    </div>

                    @* afisare tip personalitate si scor compatibilitate *@
                    @if (targetPersonality != "Unknown")
                    {
                        <div class="mt-5 p-3 bg-gradient-to-r from-[#2dd4bf]/10 via-[#facc15]/10 to-transparent rounded-lg border border-[#2dd4bf]/20 flex items-center gap-4 max-w-md">
                            <div class="size-10 rounded-full bg-gradient-to-tr from-[#2dd4bf] to-[#facc15] flex items-center justify-center shadow-lg">
                                <span class="material-symbols-outlined text-[#0f1115] text-[20px]">bolt</span>
                            </div>
                            <div>
                                <div class="text-sm font-bold text-white flex items-center gap-2">
                                    @if (!isOwnProfile && compatibilityScore > 0)
                                    {
                                        <span>@compatibilityScore% Spark Score</span>
                                        <span class="text-[10px] bg-[#2dd4bf]/20 text-[#2dd4bf] px-1.5 py-0.5 rounded border border-[#2dd4bf]/30 uppercase tracking-wider">
                                            @(compatibilityScore >= 80 ? "High" : (compatibilityScore >= 50 ? "Medium" : "Low"))
                                        </span>
                                    }
                                    else
                                    {
                                        <span>meetMi Social Identity</span>
                                    }
                                </div>
                                <div class="text-xs text-[#94a3b8] mt-0.5">Social Style: <strong>@targetPersonality</strong></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* afisare postari utilizator *@
        <div class="flex flex-col gap-6 pb-12 mt-6">
            @if (isProfileHidden)
            {
                @* mesaj pentru profil privat *@
                <div class="flex flex-col items-center justify-center py-20 bg-[#1c2228] rounded-2xl border border-dashed border-[#2d3640]">
                    <span class="material-symbols-outlined text-6xl text-[#94a3b8] mb-4">lock</span>
                    <h2 class="text-xl font-bold text-white">this account is private</h2>
                    <p class="text-[#94a3b8] text-sm">follow to see their signals</p>
                </div>
            }
            else if (userPosts != null && userPosts.Any())
            {
                @* grila de postari pe 2 coloane *@
                <div class="columns-1 md:columns-2 gap-4 space-y-4">
                    @foreach (var post in userPosts)
                    {
                        @* legare manuala a userului pentru componenta partiala *@
                        post.User = Model;
                        <partial name="PostDetails" model="post" />
                    }
                </div>
            }
            else
            {
                @* mesaj feed gol *@
                <div class="p-10 text-center border border-dashed border-[#2d3640] rounded-2xl">
                    <p class="text-[#94a3b8]">no sparks shared yet.</p>
                </div>
            }
        </div>
    </div>
</main>

<script>
    function showAdminDeleteConfirm() {
        document.getElementById('admin-delete-start').classList.add('hidden');
        document.getElementById('admin-delete-confirm-box').classList.remove('hidden');
    }
    function hideAdminDeleteConfirm() {
        document.getElementById('admin-delete-start').classList.remove('hidden');
        document.getElementById('admin-delete-confirm-box').classList.add('hidden');
    }
</script>


@section Scripts {
    <script>
        @* --- LOGICA PENTRU SPARK (LIKE) --- *@
        function toggleSpark(postId) {
            const btn = document.getElementById(`spark-btn-${postId}`);
            const countSpan = document.getElementById(`spark-count-${postId}`);
            const icon = btn.querySelector('.material-symbols-outlined');

            btn.classList.add('scale-110');
            setTimeout(() => btn.classList.remove('scale-110'), 200);

            fetch(`/Posts/ToggleReaction?postId=${postId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success || data.succes) {
                    countSpan.innerText = data.count;
                    if (data.isReacted) {
                        btn.classList.remove('text-[#94a3b8]', 'hover:text-[#2dd4bf]');
                        btn.classList.add('text-[#2dd4bf]');
                        icon.style.fontVariationSettings = "'FILL' 1";
                    } else {
                        btn.classList.add('text-[#94a3b8]', 'hover:text-[#2dd4bf]');
                        btn.classList.remove('text-[#2dd4bf]');
                        icon.style.fontVariationSettings = "'FILL' 0";
                    }
                }
            }).catch(err => console.error(err));
        }

        @* --- LOGICA PENTRU COMENTARII --- *@
        function toggleCommentsSection(postId) {
            const section = document.getElementById(`comments-section-${postId}`);
            section.classList.toggle('hidden');
            if (!section.classList.contains('hidden')) {
                setTimeout(() => {
                    const input = document.getElementById(`comment-input-${postId}`);
                    if(input) input.focus();
                }, 100);
            }
        }

        function postComment(postId) {
            const input = document.getElementById(`comment-input-${postId}`);
            const content = input.value.trim();
            if (!content) return;

            const errorDiv = document.getElementById(`comment-error-${postId}`);
            if (errorDiv) errorDiv.classList.add('hidden');

            const btn = input.nextElementSibling;
            const originalIcon = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined text-[16px] animate-spin">progress_activity</span>';

            const formData = new FormData();
            formData.append('postId', postId);
            formData.append('content', content);

            fetch('/Posts/AddComment', { method: 'POST', body: formData })
            .then(res => res.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = originalIcon;

                if (data.success || data.succes) {
                    const list = document.getElementById(`comments-list-${postId}`);
                    @* adaugam html-ul noului comentariu direct in lista *@
                    const html = `
                        <div class="flex gap-3 text-sm group animate-fade-in relative">
                            <div class="size-8 rounded-full bg-cover bg-center shrink-0 border border-[#2d3640]"
                                 style="background-image: url('${data.userImage}');"></div>
                            <div class="flex flex-col bg-[#161b20] p-2.5 rounded-r-xl rounded-bl-xl border border-[#2d3640] w-full relative">
                                <div class="flex justify-between items-baseline">
                                    <span class="text-white font-bold text-xs">${data.userName}</span>
                                    <span class="text-[#94a3b8] text-[10px]">Just now</span>
                                </div>
                                <p class="text-gray-300 text-xs mt-1">${data.content}</p>
                            </div>
                        </div>`;
                    list.insertAdjacentHTML('beforeend', html);
                    input.value = '';

                    const countBtn = document.getElementById(`comment-count-btn-${postId}`);
                    if (countBtn) {
                        let current = parseInt(countBtn.innerText.trim()) || 0;
                        countBtn.innerText = current + 1;
                    }
                } else if (errorDiv) {
                    errorDiv.innerText = data.message;
                    errorDiv.classList.remove('hidden');
                }
            }).catch(err => {
                btn.disabled = false;
                btn.innerHTML = originalIcon;
                console.error(err);
            });
        }

        @* --- LOGICA PENTRU STERGERI SI CONFIRMARI --- *@
        function showPostConfirm(id) {
            const el = document.getElementById(`post-confirm-${id}`);
            if(el) el.classList.remove('hidden');
        }
        function hidePostConfirm(id) {
            const el = document.getElementById(`post-confirm-${id}`);
            if(el) el.classList.add('hidden');
        }

        @* functii pentru confirmari comentarii (daca e cazul) *@
        function showConfirm(id) { 
            const el = document.getElementById(`confirm-${id}`);
            if(el) el.classList.remove('hidden'); 
        }
        function hideConfirm(id) { 
            const el = document.getElementById(`confirm-${id}`);
            if(el) el.classList.add('hidden'); 
        }
    </script>

    @* stiluri pentru animatiile de incarcare si aparitie *@
    <style>
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
        .animate-spin { animation: spin 1s linear infinite; }
        @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>
}