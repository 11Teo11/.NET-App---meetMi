@model ProiectDotNet.Models.ApplicationUser

@{
    ViewData["Title"] = "Edit Profile";
    Layout = "/Views/Shared/_LayoutTest.cshtml";
}

<div class="w-full max-w-2xl mx-auto py-12 px-4">
    <div class="bg-[#1c2228] p-8 rounded-3xl border border-[#2d3640] shadow-2xl relative overflow-hidden">

        @* titlu si buton back *@
        <div class="flex items-center gap-4 mb-8 relative z-10">
            @* link inapoi catre profilul curent *@
            <a href="/Profiles/Show/@Model.Id" class="p-2 rounded-full hover:bg-[#2d3640] text-[#94a3b8] hover:text-white transition-colors">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <h1 class="text-3xl font-black text-white tracking-tight">Edit Profile</h1>
        </div>

        @* formularul principal *@
        @* IMPORTANT: enctype="multipart/form-data" este obligatoriu pentru upload de poze *@
        <form asp-action="Edit" asp-controller="Profiles" method="post" enctype="multipart/form-data" class="flex flex-col gap-6 relative z-10">

            @* --- 1. POZA DE PROFIL --- *@
            <div class="flex items-center gap-6 p-4 bg-[#161b20] rounded-2xl border border-[#2d3640]">
                <div class="shrink-0">
                    <div class="size-20 rounded-full bg-cover bg-center border-2 border-[#2d3640]"
                         style="background-image: url('@(Model.ProfilePicture ?? "/images/default-avatar.png")');"></div>
                </div>
                <div class="flex-1">
                    <label class="text-xs font-bold text-[#94a3b8] uppercase mb-2 block">Change Profile Picture</label>
                    @* nume "ProfileImage" trebuie sa corespunda cu parametrul din Controller *@
                    <input type="file" name="ProfileImage"
                           class="w-full text-[#94a3b8] text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-[#2dd4bf]/10 file:text-[#2dd4bf] hover:file:bg-[#2dd4bf]/20 cursor-pointer transition-colors" />
                </div>
            </div>

            @* --- 2. NUME SI PRENUME --- *@
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1">
                    <label asp-for="FirstName" class="text-xs font-bold text-[#94a3b8] uppercase mb-2 block">First Name</label>
                    <input asp-for="FirstName" class="w-full bg-[#0f1115] border border-[#2d3640] rounded-xl text-white px-4 py-3 focus:border-[#2dd4bf] focus:ring-1 focus:ring-[#2dd4bf] outline-none transition-all font-bold placeholder-[#52525b]" />
                    <span asp-validation-for="FirstName" class="text-red-500 text-xs font-bold mt-1 block"></span>
                </div>
                <div class="flex-1">
                    <label asp-for="LastName" class="text-xs font-bold text-[#94a3b8] uppercase mb-2 block">Last Name</label>
                    <input asp-for="LastName" class="w-full bg-[#0f1115] border border-[#2d3640] rounded-xl text-white px-4 py-3 focus:border-[#2dd4bf] focus:ring-1 focus:ring-[#2dd4bf] outline-none transition-all font-bold placeholder-[#52525b]" />
                    <span asp-validation-for="LastName" class="text-red-500 text-xs font-bold mt-1 block"></span>
                </div>
            </div>

            @* --- 3. DESCRIERE (BIO) --- *@
            <div>
                <label asp-for="Description" class="text-xs font-bold text-[#94a3b8] uppercase mb-2 block">Bio / Description</label>
                <textarea asp-for="Description" rows="4"
                          class="w-full bg-[#0f1115] border border-[#2d3640] rounded-xl text-white px-4 py-3 focus:border-[#2dd4bf] focus:ring-1 focus:ring-[#2dd4bf] outline-none transition-all resize-none placeholder-[#52525b]"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs font-bold mt-1 block"></span>
            </div>

            @* --- 4. VIZIBILITATE --- *@
            <div>
                <label asp-for="Visibility" class="text-xs font-bold text-[#94a3b8] uppercase mb-2 block">Profile Visibility</label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @* Optiunea Public *@
                    <label class="cursor-pointer relative">
                        <input type="radio" asp-for="Visibility" value="public" class="peer sr-only" />
                        <div class="p-4 rounded-xl border border-[#2d3640] bg-[#0f1115] peer-checked:border-[#2dd4bf] peer-checked:bg-[#2dd4bf]/10 transition-all flex items-center gap-3 group h-full">
                            <span class="material-symbols-outlined text-[#94a3b8] group-hover:text-white peer-checked:text-[#2dd4bf]">public</span>
                            <div>
                                <div class="text-white font-bold text-sm">Public</div>
                                <div class="text-[#52525b] text-xs">Everyone can follow you</div>
                            </div>
                            @* cerculet selectie *@
                            <div class="absolute top-4 right-4 size-4 rounded-full border border-[#2d3640] peer-checked:border-[#2dd4bf] peer-checked:bg-[#2dd4bf]"></div>
                        </div>
                    </label>

                    @* Optiunea Private *@
                    <label class="cursor-pointer relative">
                        <input type="radio" asp-for="Visibility" value="private" class="peer sr-only" />
                        <div class="p-4 rounded-xl border border-[#2d3640] bg-[#0f1115] peer-checked:border-[#2dd4bf] peer-checked:bg-[#2dd4bf]/10 transition-all flex items-center gap-3 group h-full">
                            <span class="material-symbols-outlined text-[#94a3b8] group-hover:text-white peer-checked:text-[#2dd4bf]">lock</span>
                            <div>
                                <div class="text-white font-bold text-sm">Private</div>
                                <div class="text-[#52525b] text-xs">Approve followers manually</div>
                            </div>
                            @* cerculet selectie *@
                            <div class="absolute top-4 right-4 size-4 rounded-full border border-[#2d3640] peer-checked:border-[#2dd4bf] peer-checked:bg-[#2dd4bf]"></div>
                        </div>
                    </label>
                </div>
            </div>

            @* --- BUTON SAVE --- *@
            <div class="mt-4 pt-6 border-t border-[#2d3640] flex justify-end gap-4">
                <a href="/Profiles/Show/@Model.Id" class="py-3 px-6 rounded-xl border border-[#2d3640] text-[#94a3b8] font-bold hover:text-white hover:bg-[#2d3640] transition-all text-sm uppercase tracking-widest text-decoration-none">
                    Cancel
                </a>
                <button type="submit" class="bg-gradient-to-r from-[#2dd4bf] to-[#22d3ee] text-[#0f1115] font-black py-3 px-8 rounded-xl hover:opacity-90 transition-all shadow-lg hover:shadow-[#2dd4bf]/20 text-sm uppercase tracking-widest border-0">
                    Save Changes
                </button>
            </div>

        </form>


        @* sectiune de stergere cont pentru utilizatorul curent *@
        <div class="mt-12 pt-8 border-t border-red-500/20">
            <div class="flex flex-col gap-4">
                <div>
                    <h3 class="text-red-500 font-black text-sm uppercase tracking-widest">Danger Zone</h3>
                    <p class="text-[#94a3b8] text-xs mt-1">Once you delete your profile, there is no going back. Please be certain.</p>
                </div>
                
                @* butonul initial de stergere *@
                <button type="button" id="btn-delete-start" onclick="showDeleteConfirm()" class="w-full md:w-auto bg-transparent border border-red-500/50 text-red-500 hover:bg-red-500 hover:text-white font-bold py-3 px-8 rounded-xl transition-all text-sm uppercase tracking-widest">
                    Delete My Account
                </button>

                @* zona de confirmare integrata - ascunsa initial *@
                <div id="delete-confirmation-box" class="hidden bg-red-500/5 border border-red-500/20 p-6 rounded-2xl flex flex-col gap-4 animate-pulse-slow">
                    <p class="text-white text-sm font-bold">Are you absolutely sure? All your data will be permanently removed.</p>
                    <div class="flex gap-3">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="bg-red-500 text-white font-black py-2 px-6 rounded-lg hover:bg-red-600 transition-all text-xs uppercase tracking-widest border-0">
                                Yes, Delete Everything
                            </button>
                        </form>
                        <button type="button" onclick="hideDeleteConfirm()" class="bg-[#2d3640] text-white py-2 px-6 rounded-lg hover:bg-[#3d4752] transition-all text-xs uppercase tracking-widest border-0">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
</div>

<script>
    // functia care afiseaza caseta de confirmare
    function showDeleteConfirm() {
        document.getElementById('btn-delete-start').classList.add('hidden');
        document.getElementById('delete-confirmation-box').classList.remove('hidden');
    }
    // functia care ascunde caseta de confirmare daca userul se razgandeste
    function hideDeleteConfirm() {
        document.getElementById('btn-delete-start').classList.remove('hidden');
        document.getElementById('delete-confirmation-box').classList.add('hidden');
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}